{
  "openapi": "3.0.3",
  "info": {
    "title": "Local Apps API",
    "description": "Monitor, manage, and sync local development apps across machines. Provides health checking, Caddy reverse proxy setup, macOS LaunchAgent management, screenshot capture, and cross-machine sync.",
    "version": "1.0.0",
    "contact": {
      "name": "Bunlong Heng",
      "url": "https://bheng.dev"
    }
  },
  "servers": [
    {
      "url": "http://localhost:9876",
      "description": "Local development"
    }
  ],
  "tags": [
    { "name": "Apps", "description": "CRUD operations for registered apps" },
    { "name": "Status", "description": "Health monitoring and live updates" },
    { "name": "Machines", "description": "Manage peer machines for multi-machine dashboard" },
    { "name": "Machine Sync", "description": "Cross-machine app list synchronization" },
    { "name": "Screenshots", "description": "Automated screenshot capture and management" },
    { "name": "Icons", "description": "Favicon generation and management" },
    { "name": "Utilities", "description": "QR codes, logs, and other helpers" }
  ],
  "paths": {
    "/api/apps": {
      "get": {
        "tags": ["Apps"],
        "summary": "List all apps",
        "description": "Returns the full list of registered apps from the database.",
        "responses": {
          "200": {
            "description": "Array of apps",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/App" }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Apps"],
        "summary": "Register a new app",
        "description": "Registers a new app and auto-provisions infrastructure: port assignment, Caddy reverse proxy entry, macOS LaunchAgent plist, and health check enrollment.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AppCreate" },
              "example": {
                "id": "my-app",
                "name": "My App",
                "localPath": "/Users/me/Sites/my-app",
                "repo": "https://github.com/me/my-app"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "App created with auto-provisioned infra",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/App" }
              }
            }
          },
          "400": {
            "description": "Missing required field (id)",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/api/apps/{id}": {
      "get": {
        "tags": ["Apps"],
        "summary": "Get a single app",
        "parameters": [
          { "$ref": "#/components/parameters/AppId" }
        ],
        "responses": {
          "200": {
            "description": "App details",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/App" }
              }
            }
          },
          "404": {
            "description": "App not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      },
      "put": {
        "tags": ["Apps"],
        "summary": "Update an app",
        "description": "Partial update — only provided fields are changed. Re-provisions Caddy and LaunchAgent if localUrl or localPath changes.",
        "parameters": [
          { "$ref": "#/components/parameters/AppId" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AppUpdate" },
              "example": {
                "localUrl": "http://localhost:4000",
                "icon": "/favicons/my-app.svg"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated app",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/App" }
              }
            }
          },
          "404": {
            "description": "App not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      },
      "delete": {
        "tags": ["Apps"],
        "summary": "Delete an app",
        "description": "Removes the app from the database, deletes its Caddy reverse proxy entry, and unloads its LaunchAgent.",
        "parameters": [
          { "$ref": "#/components/parameters/AppId" }
        ],
        "responses": {
          "200": {
            "description": "App deleted",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": { "type": "boolean", "example": true }
                  }
                }
              }
            }
          },
          "404": {
            "description": "App not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/api/status": {
      "get": {
        "tags": ["Status"],
        "summary": "Dashboard status",
        "description": "Returns all apps with live health status, LAN URLs, screenshot availability, machine hostname, model, and IP address.",
        "responses": {
          "200": {
            "description": "Full dashboard payload",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "apps": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/AppStatus" }
                    },
                    "lanIp": { "type": "string", "example": "10.0.0.218" },
                    "machineModel": { "type": "string", "example": "Mac mini", "nullable": true },
                    "monitorUrl": { "type": "string", "example": "http://10.0.0.218:9876" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/events": {
      "get": {
        "tags": ["Status"],
        "summary": "SSE event stream",
        "description": "Server-Sent Events stream for real-time updates. Event types: `update` (app status change), `alert` (app went down), `reload` (config changed), `screenshots_done` (capture completed).",
        "responses": {
          "200": {
            "description": "SSE stream",
            "content": {
              "text/event-stream": {
                "schema": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "/api/log/{id}": {
      "get": {
        "tags": ["Utilities"],
        "summary": "Get app log tail",
        "description": "Returns the last 30 lines from the app's log file.",
        "parameters": [
          { "$ref": "#/components/parameters/AppId" }
        ],
        "responses": {
          "200": {
            "description": "Log lines",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "lines": {
                      "type": "array",
                      "items": { "type": "string" }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/start/{id}": {
      "post": {
        "tags": ["Status"],
        "summary": "Start an app",
        "description": "Loads and starts the app's macOS LaunchAgent plist.",
        "parameters": [
          { "$ref": "#/components/parameters/AppId" }
        ],
        "responses": {
          "200": {
            "description": "App started",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": { "type": "boolean", "example": true }
                  }
                }
              }
            }
          },
          "400": {
            "description": "No LaunchAgent configured",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "404": {
            "description": "App not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/api/qr": {
      "get": {
        "tags": ["Utilities"],
        "summary": "QR code for LAN access",
        "description": "Returns a QR code image (base64 data URL) pointing to the LAN dashboard URL.",
        "responses": {
          "200": {
            "description": "QR code data",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "url": { "type": "string", "example": "http://10.0.0.218:9876" },
                    "dataUrl": { "type": "string", "description": "Base64 PNG data URL" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/machines": {
      "get": {
        "tags": ["Machines"],
        "summary": "List peer machines",
        "description": "Returns all saved peer machines from the database.",
        "responses": {
          "200": {
            "description": "Array of machines",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Machine" }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Machines"],
        "summary": "Add a peer machine",
        "description": "Adds a remote machine by IP. Attempts to fetch /api/machine from the remote to get hostname and model.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["ip"],
                "properties": {
                  "ip": { "type": "string", "description": "LAN IP address", "example": "10.0.0.218" },
                  "port": { "type": "integer", "description": "Monitor port (default 9876)", "example": 9876 }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Machine added",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Machine" }
              }
            }
          },
          "400": {
            "description": "Missing ip",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/api/machines/{id}": {
      "delete": {
        "tags": ["Machines"],
        "summary": "Remove a peer machine",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "Machine ID (hostname or IP)"
          }
        ],
        "responses": {
          "200": {
            "description": "Machine removed",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "deleted": { "type": "boolean" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/machine": {
      "get": {
        "tags": ["Machine Sync"],
        "summary": "Machine identity",
        "description": "Returns this machine's hostname, hardware model, LAN IP, monitor port, and number of registered apps.",
        "responses": {
          "200": {
            "description": "Machine info",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MachineInfo" }
              }
            }
          }
        }
      }
    },
    "/api/apps/export": {
      "get": {
        "tags": ["Machine Sync"],
        "summary": "Export portable app list",
        "description": "Returns app list without machine-specific paths (localPath, logPath). Used by `/api/sync` to merge apps across machines.",
        "responses": {
          "200": {
            "description": "Portable app list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "hostname": { "type": "string" },
                    "lanIp": { "type": "string" },
                    "apps": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/AppExport" }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/sync": {
      "post": {
        "tags": ["Machine Sync"],
        "summary": "Sync from remote machine",
        "description": "Connects to another Local Apps instance and merges its app list into this machine. Adds missing apps (with localPath derived from ~/Sites/{id}), and syncs ports/repos/icons for existing apps.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["remote"],
                "properties": {
                  "remote": {
                    "type": "string",
                    "description": "IP or IP:port of remote machine",
                    "example": "10.0.0.218"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Sync result",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SyncResult" }
              }
            }
          },
          "400": {
            "description": "Missing remote parameter",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "502": {
            "description": "Failed to reach remote machine",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/api/screenshots": {
      "get": {
        "tags": ["Screenshots"],
        "summary": "Global screenshot index",
        "description": "Returns the global screenshots index.json if it exists.",
        "responses": {
          "200": {
            "description": "Screenshot index",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "type": "object" }
                }
              }
            }
          }
        }
      }
    },
    "/api/screenshots/{id}": {
      "get": {
        "tags": ["Screenshots"],
        "summary": "Get screenshots for an app",
        "description": "Returns the screenshot index (desktop/mobile lists) for a specific app.",
        "parameters": [
          { "$ref": "#/components/parameters/AppId" }
        ],
        "responses": {
          "200": {
            "description": "Screenshot data",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": { "type": "string" },
                    "desktop": {
                      "type": "array",
                      "items": { "type": "string" }
                    },
                    "mobile": {
                      "type": "array",
                      "items": { "type": "string" }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Screenshots"],
        "summary": "Capture screenshots",
        "description": "Triggers the Playwright screenshot bot for the specified app. Runs asynchronously in the background. Broadcasts `screenshots_done` SSE event on completion.",
        "parameters": [
          { "$ref": "#/components/parameters/AppId" }
        ],
        "responses": {
          "200": {
            "description": "Capture started or already running",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "enum": ["started", "already_running"]
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "App not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/api/screenshots-status": {
      "get": {
        "tags": ["Screenshots"],
        "summary": "Running screenshot jobs",
        "description": "Returns currently active screenshot capture jobs with their start times.",
        "responses": {
          "200": {
            "description": "Active jobs map",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "object",
                    "properties": {
                      "startedAt": { "type": "string", "format": "date-time" }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/screenshot": {
      "delete": {
        "tags": ["Screenshots"],
        "summary": "Delete a screenshot",
        "description": "Deletes a specific screenshot file and removes it from the app's index.json.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["appId", "mode", "filename"],
                "properties": {
                  "appId": { "type": "string", "description": "App ID" },
                  "mode": { "type": "string", "enum": ["desktop", "mobile"], "description": "Screenshot mode" },
                  "filename": { "type": "string", "description": "Screenshot filename (no path)" }
                }
              },
              "example": {
                "appId": "bheng",
                "mode": "desktop",
                "filename": "home.png"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Screenshot deleted",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": { "type": "boolean", "example": true }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Missing fields or invalid filename",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/api/retake": {
      "post": {
        "tags": ["Screenshots"],
        "summary": "Toggle retake flag",
        "description": "Marks or unmarks a screenshot for retake. Stored in the app's retake.json.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["appId", "mode", "filename"],
                "properties": {
                  "appId": { "type": "string" },
                  "mode": { "type": "string", "enum": ["desktop", "mobile"] },
                  "filename": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Retake toggled",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "marked": { "type": "boolean" }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Missing fields",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/api/retake/{appId}": {
      "get": {
        "tags": ["Screenshots"],
        "summary": "Get retake list",
        "description": "Returns the retake.json for an app — a map of screenshots flagged for retake.",
        "parameters": [
          {
            "name": "appId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "App identifier"
          }
        ],
        "responses": {
          "200": {
            "description": "Retake map",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": { "type": "boolean" }
                }
              }
            }
          }
        }
      }
    },
    "/api/generate-icons/{id}": {
      "post": {
        "tags": ["Icons"],
        "summary": "Generate favicons for one app",
        "description": "Finds the best source icon (SVG/PNG) and generates favicon.ico (16+32), apple-touch-icon.png (180), and icon.png (512). Runs asynchronously.",
        "parameters": [
          { "$ref": "#/components/parameters/AppId" }
        ],
        "responses": {
          "200": {
            "description": "Generation started or already running",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string", "enum": ["started", "already_running"] }
                  }
                }
              }
            }
          },
          "404": {
            "description": "App not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/api/generate-icons": {
      "post": {
        "tags": ["Icons"],
        "summary": "Generate favicons for all apps",
        "description": "Runs the favicon generator for every registered app. Skips apps that are already complete (e.g. mindmaps). Runs asynchronously.",
        "responses": {
          "200": {
            "description": "Bulk generation started",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string", "enum": ["started", "already_running"] }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/generate-icons/status": {
      "get": {
        "tags": ["Icons"],
        "summary": "Icon generation job status",
        "description": "Returns currently running icon generation jobs.",
        "responses": {
          "200": {
            "description": "Active jobs",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "object",
                    "properties": {
                      "startedAt": { "type": "string", "format": "date-time" }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "parameters": {
      "AppId": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": { "type": "string" },
        "description": "App identifier (kebab-case)",
        "example": "bheng"
      }
    },
    "schemas": {
      "App": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "example": "bheng" },
          "name": { "type": "string", "example": "bheng" },
          "healthUrl": { "type": "string", "example": "http://localhost:3000" },
          "localUrl": { "type": "string", "example": "http://localhost:3000" },
          "repo": { "type": "string", "example": "https://github.com/bunlongheng/bheng", "nullable": true },
          "localPath": { "type": "string", "example": "/Users/bheng/Sites/bheng", "nullable": true },
          "logPath": { "type": "string", "example": "/tmp/bheng.log", "nullable": true },
          "startCommand": { "type": "string", "example": "npm run dev", "nullable": true },
          "icon": { "type": "string", "nullable": true },
          "caddyUrl": { "type": "string", "example": "http://bheng.localhost", "nullable": true },
          "launchAgent": { "type": "string", "nullable": true },
          "launchAgentPath": { "type": "string", "nullable": true }
        }
      },
      "AppCreate": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": { "type": "string", "description": "Unique identifier (kebab-case)" },
          "name": { "type": "string", "description": "Display name (defaults to id)" },
          "localPath": { "type": "string", "description": "Absolute path to project root" },
          "localUrl": { "type": "string", "description": "Local URL (auto-assigned if omitted)" },
          "healthUrl": { "type": "string", "description": "Health check URL (defaults to localUrl)" },
          "repo": { "type": "string", "description": "GitHub repo URL" },
          "startCommand": { "type": "string", "description": "Start command (defaults to 'npm run dev')" },
          "icon": { "type": "string", "description": "URL or path to app icon" },
          "logPath": { "type": "string", "description": "Log file path (defaults to /tmp/{id}.log)" }
        }
      },
      "AppUpdate": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "localPath": { "type": "string" },
          "localUrl": { "type": "string" },
          "healthUrl": { "type": "string" },
          "repo": { "type": "string" },
          "startCommand": { "type": "string" },
          "icon": { "type": "string" },
          "logPath": { "type": "string" }
        }
      },
      "AppStatus": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "localUrl": { "type": "string" },
          "lanUrl": { "type": "string", "nullable": true },
          "status": { "type": "string", "enum": ["up", "down", "unknown"] },
          "lastChecked": { "type": "string", "format": "date-time", "nullable": true },
          "caddyUrl": { "type": "string", "nullable": true },
          "launchAgent": { "type": "string", "nullable": true },
          "launchAgentPath": { "type": "string", "nullable": true },
          "icon": { "type": "string", "nullable": true },
          "repo": { "type": "string", "nullable": true },
          "localPath": { "type": "string", "nullable": true },
          "logPath": { "type": "string", "nullable": true },
          "hostname": { "type": "string" },
          "hasScreenshots": { "type": "boolean" }
        }
      },
      "AppExport": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "healthUrl": { "type": "string" },
          "localUrl": { "type": "string" },
          "repo": { "type": "string", "nullable": true },
          "startCommand": { "type": "string", "nullable": true },
          "icon": { "type": "string", "nullable": true }
        }
      },
      "Machine": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "example": "Bunlongs-Mac-mini.local" },
          "hostname": { "type": "string", "example": "Bunlongs-Mac-mini.local", "nullable": true },
          "ip": { "type": "string", "example": "10.0.0.218" },
          "port": { "type": "integer", "example": 9876 },
          "model": { "type": "string", "example": "Mac mini", "nullable": true },
          "last_seen": { "type": "string", "format": "date-time" }
        }
      },
      "MachineInfo": {
        "type": "object",
        "properties": {
          "hostname": { "type": "string", "example": "Bunlongs-Mac-mini.local" },
          "model": { "type": "string", "example": "Mac mini", "nullable": true },
          "lanIp": { "type": "string", "example": "10.0.0.218" },
          "port": { "type": "integer", "example": 9876 },
          "appCount": { "type": "integer", "example": 10 }
        }
      },
      "SyncResult": {
        "type": "object",
        "properties": {
          "synced": { "type": "boolean", "example": true },
          "remote": {
            "type": "object",
            "properties": {
              "hostname": { "type": "string" },
              "ip": { "type": "string" }
            }
          },
          "added": { "type": "integer", "description": "Number of new apps added" },
          "updated": { "type": "integer", "description": "Number of existing apps updated" },
          "total": { "type": "integer", "description": "Total apps after sync" }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": { "type": "string" }
        }
      }
    }
  }
}
